# 1. 在 @BotFather 创建机器人，拿到 Token
TG_TOKEN=123456789:ABCDEFGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2. 在机器人对话框发任意消息，访问下面链接查 chat_id：
#    https://api.telegram.org/bot<TG_TOKEN>/getUpdates
TG_CHAT_ID=-1001234567890

# 可选：REST 兜底轮询和 WS 断线重连间隔，单位秒
POLL_INTERVAL=3
WS_RECONNECT_DELAY=5
WS_URLS=wss://wss-flash-2.jin10.com/
HISTORY_DB=data/jin10_history.sqlite3
JIN10_APP_IDS=bVBF4FyRTn5NJF5n,SO1EJGmNgCtmpcPF
PUSH_IMPORTANT=1
# 可选：Telegram 消息末尾附本地 Dashboard 详情链接；留空则 Telegram 文本保持原样
# DASHBOARD_URL=http://127.0.0.1:8765

# 可选：Dashboard 行情叠加；默认不配置，不请求外部行情 API
# MARKET_ADAPTER=binance
# MARKET_TIMEOUT_SECONDS=3
# MARKET_CACHE_TTL_SECONDS=600
# BINANCE_SPOT_BASE_URL=https://api.binance.com

# 可选：Dashboard LLM Provider；默认不配置，不会请求模型 API
# 免费优先试用建议：先申请 Google AI Studio / Gemini API key
# PROVIDER_TIMEOUT_SECONDS=45
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_MAX_TOKENS=1800
# 可选：Gemini 2.5 thinking budget；设为 0 可减少延迟，留空使用模型默认
# GEMINI_THINKING_BUDGET=0

# 可选：Anthropic Messages API；付费后再启用
# ANTHROPIC_API_KEY=your-anthropic-api-key
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_MAX_TOKENS=1800

# 可选：DeepSeek / GLM 等 OpenAI-compatible API
# COMPAT_LLM_LABEL=DeepSeek
# COMPAT_LLM_BASE_URL=https://api.deepseek.com
# COMPAT_LLM_API_KEY=your-compatible-api-key
# COMPAT_LLM_MODEL=deepseek-v4-flash
# COMPAT_LLM_MAX_TOKENS=1800

# 可选：实验性 ChatGPT Web 本机代理入口；仅建议指向 127.0.0.1 自托管 OpenAI-compatible 代理
# 不要接入公共未知代理，不要导入主 ChatGPT 账号凭据；默认不配置、不启用
# CHATGPT_PROXY_LABEL=ChatGPT Proxy
# CHATGPT_PROXY_BASE_URL=http://127.0.0.1:5083/v1
# CHATGPT_PROXY_API_KEY=your-local-proxy-bearer-token
# CHATGPT_PROXY_MODEL=gpt-4o
# CHATGPT_PROXY_MAX_TOKENS=1800
# CHATGPT_PROXY_TEMPERATURE=0.2

# 事件聚合防刷屏 V2：默认关闭；开启后相似实时快讯在窗口内只推第一条，后续只入库并记录 skipped 诊断状态
AGGREGATION_V2=0
AGGREGATION_WINDOW_SECONDS=180      # 范围 0-3600；0 表示关闭聚合窗口
AGGREGATION_BYPASS_IMPORTANT=1      # T3 金十重要消息绕过聚合，仍然直推

# 可选：关键词外部配置文件，一行一个关键词，支持 # 注释
# 不配置时使用代码内置默认关键词；文件读取失败或为空时也会回退到内置默认
# KEYWORDS_FILE=config/keywords.txt
# HIGH_PRIORITY_FILE=config/high_priority.txt

# 离线补拉：启动时自动补齐上次入库到本次启动之间的消息
AUTO_CATCHUP=1
CATCHUP_TELEGRAM=1
CATCHUP_MAX_HOURS=24        # 范围 1-168
CATCHUP_MAX_STORE=1000      # 范围 20-5000
CATCHUP_MAX_SEND=120        # 范围 0-300；0 表示不逐条补发
CATCHUP_SEND_INTERVAL=0.5   # 范围 0-10；0 表示不等待
# 常驻进程从睡眠/长时间断网恢复后，检测到轮询停顿超过该秒数会补拉一次摘要；设为 0 可关闭
AUTO_CATCHUP_GAP_SECONDS=300  # 范围 0-86400
# 消息发生时间距当前超过该秒数时，在 Telegram/终端显示“延迟：Xs”；设为 0 可关闭
SHOW_DELAY_IF_SECONDS=60      # 范围 0-3600

# 安全保护：HISTORY_DB=/tmp/... 临时测试库默认不真实发送 Telegram
# 如确实要用临时库测试真实推送，手动改为 1
ALLOW_TMP_TELEGRAM=0
