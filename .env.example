# 1. 在 @BotFather 创建机器人，拿到 Token
TG_TOKEN=123456789:ABCDEFGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2. 在机器人对话框发任意消息，访问下面链接查 chat_id：
#    https://api.telegram.org/bot<TG_TOKEN>/getUpdates
TG_CHAT_ID=-1001234567890

# 可选：REST 兜底轮询和 WS 断线重连间隔，单位秒
POLL_INTERVAL=3
WS_RECONNECT_DELAY=5
WS_URLS=wss://wss-flash-2.jin10.com/
HISTORY_DB=data/jin10_history.sqlite3
JIN10_APP_IDS=bVBF4FyRTn5NJF5n,SO1EJGmNgCtmpcPF
